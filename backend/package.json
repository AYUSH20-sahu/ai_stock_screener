{
    "name": "@ai-stock-screener/backend",
    "private": true,
    "main": "dist/index.js",
    "type": "commonjs",
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev --name init",
        "prisma:seed": "prisma db seed",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@prisma/client": "^6.0.0",
        "bcrypt": "^5.1.1",
        "compression": "^1.7.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "yahoo-finance2": "^4.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.0",
        "@types/cors": "^2.8.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.10",
        "@types/node": "^22.10.1",
        "@types/supertest": "^7.2.1",
        "jest": "^30.4.2",
        "nodemon": "^3.1.14",
        "prisma": "^6.0.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}